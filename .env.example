# Copy to .env and fill in. .env is gitignored.

# Displayed app name (white-label) — shown as the title, heading, PWA name,
# etc. Defaults to "python3" if unset.
APP_NAME=

# Cloudflare Tunnel token (Zero Trust dashboard -> Networks -> Tunnels).
# Used by the `cloudflared` service in docker-compose.yaml.
TUNNEL_TOKEN=

# --- TOTP login gate (auth service) ---
# Base32 TOTP secret shared with your authenticator app. Generate one with:
#   head -c20 /dev/urandom | base32 | tr -d '='
# Then add it to Google Authenticator / Authy / 1Password as a manual key.
TOTP_SEED=

# Random key used to sign session cookies (>= 16 chars). Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# The proxy FAILS TO START if TOTP_SEED/SESSION_SECRET are missing, to avoid
# accidentally serving the client with no authentication on a public tunnel.
# Set AUTH_DISABLED=true to intentionally run with no login gate (dev/test only).
AUTH_DISABLED=

# How long a session lasts after a successful code entry (Go duration).
SESSION_TTL=12h

# --- Per-source-IP new-connection limit ---
# The proxy throttles new connections per source IP (default 1/sec, burst 1),
# which breaks reverse-proxying many short-lived connections (e.g. HTTP/1.0).
# "off" disables it; or set a number (connections/sec) and an optional burst.
SRC_CONN_RATE=off
SRC_CONN_BURST=
